---
import "../styles/global.css";
import { SITE_URL, localizePath, type Locale } from "../lib/i18n";
import { uiText } from "../lib/content";

interface Props {
  lang: Locale;
  title: string;
  description: string;
  canonicalPath: string;
  switchUrls: Record<Locale, string>;
  hreflangUrls?: Partial<Record<Locale, string>>;
  noindex?: boolean;
}

const {
  lang,
  title,
  description,
  canonicalPath,
  switchUrls,
  hreflangUrls = {},
  noindex = false,
} = Astro.props;

const pageTitle = `${title} | ${uiText.siteName}`;
const fullCanonical = new URL(canonicalPath, SITE_URL).toString();

const resolvedHreflangs: Partial<Record<Locale, string>> = {
  [lang]: canonicalPath,
  ...hreflangUrls,
};

const navLinks = [
  { href: localizePath(lang, "/photos"), label: uiText.navigation.photos[lang] },
  { href: localizePath(lang, "/blog"), label: uiText.navigation.blog[lang] },
  { href: localizePath(lang, "/products"), label: uiText.navigation.products[lang] },
  { href: localizePath(lang, "/contacts"), label: uiText.navigation.contacts[lang] },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={fullCanonical} />
    {resolvedHreflangs.ru && (
      <link rel="alternate" hrefLang="ru" href={new URL(resolvedHreflangs.ru, SITE_URL).toString()} />
    )}
    {resolvedHreflangs.en && (
      <link rel="alternate" hrefLang="en" href={new URL(resolvedHreflangs.en, SITE_URL).toString()} />
    )}
    <link rel="alternate" hrefLang="x-default" href={new URL("/", SITE_URL).toString()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <slot name="head" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container nav-wrap">
        <a class="brand" href={localizePath(lang)}>{uiText.siteName}</a>
        <div class="nav-tools">
          <nav>
            {navLinks.map((item) => (
              <a href={item.href}>{item.label}</a>
            ))}
          </nav>
          <div class="lang-switch" aria-label={uiText.languageSwitchLabel[lang]}>
            <a
              class:list={["lang-btn", { "is-active": lang === "ru" }]}
              href={switchUrls.ru}
              data-lang-set="ru"
              aria-current={lang === "ru" ? "page" : undefined}
            >
              RU
            </a>
            <a
              class:list={["lang-btn", { "is-active": lang === "en" }]}
              href={switchUrls.en}
              data-lang-set="en"
              aria-current={lang === "en" ? "page" : undefined}
            >
              EN
            </a>
          </div>
        </div>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-wrap">
        <p>© {new Date().getFullYear()} {uiText.siteName}</p>
        <div class="footer-links">
          <a href={localizePath(lang, "/privacy")}>{uiText.navigation.privacy[lang]}</a>
          <a href={localizePath(lang, "/terms")}>{uiText.navigation.terms[lang]}</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const key = "minnerom_lang";
        const year = 60 * 60 * 24 * 365;

        document.querySelectorAll("[data-lang-set]").forEach((link) => {
          link.addEventListener("click", () => {
            const nextLang = link.getAttribute("data-lang-set");
            if (!nextLang) {
              return;
            }

            document.cookie = `${key}=${nextLang}; Max-Age=${year}; Path=/; SameSite=Lax`;
          });
        });
      })();
    </script>
  </body>
</html>
