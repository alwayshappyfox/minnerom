---
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  const products = [
    {
      slug: "print-a3-demo",
      name: "Print A3 (Demo)",
      descriptionRu: "Демонстрационная карточка товара без оплаты.",
      descriptionEn: "Demo product page without checkout.",
      detailsRu:
        "Будущий путь: добавить цены, остатки и checkout через Shopify/Snipcart/другой сервис.",
      detailsEn:
        "Future path: add pricing, stock, and checkout via Shopify/Snipcart/another service.",
    },
  ];

  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
---

<BaseLayout
  title={product.name}
  titleEn={product.name}
  description={product.descriptionRu}
  descriptionEn={product.descriptionEn}
>
  <article class="card">
    <h1 class="page-title">{product.name}</h1>
    <div class="fake-media" data-i18n data-i18n-ru="Изображение товара" data-i18n-en="Product image">
      Изображение товара
    </div>
    <p data-i18n data-i18n-ru={product.descriptionRu} data-i18n-en={product.descriptionEn}>
      {product.descriptionRu}
    </p>
    <p class="muted" data-i18n data-i18n-ru={product.detailsRu} data-i18n-en={product.detailsEn}>
      {product.detailsRu}
    </p>
    <p>
      <a
        href="/products"
        data-i18n
        data-i18n-ru="← Назад к витрине"
        data-i18n-en="← Back to showcase"
      >
        ← Назад к витрине
      </a>
    </p>
  </article>
</BaseLayout>
