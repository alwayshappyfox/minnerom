---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getProductsByLocale, metaText, localizedPathPair, productsIntro } from "../../../lib/content";
import { LOCALES, localizePath, type Locale } from "../../../lib/i18n";
import { productCardAsset, toResponsiveImage } from "../../../lib/media";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: Locale };
const products = getProductsByLocale(lang);
const canonicalPath = localizePath(lang, "/products");
const switchUrls = localizedPathPair(lang, "/products");
---

<BaseLayout
  lang={lang}
  title={metaText.productsTitle[lang]}
  description={metaText.productsDescription[lang]}
  canonicalPath={canonicalPath}
  switchUrls={switchUrls}
  hreflangUrls={{
    ru: localizePath("ru", "/products"),
    en: localizePath("en", "/products"),
  }}
>
  <h1 class="page-title">{metaText.productsTitle[lang]}</h1>
  <p class="muted">{productsIntro[lang]}</p>

  <section class="grid">
    {products.map((product) => {
      const slug = product.slug[lang];
      if (!slug) {
        return null;
      }
      const image = toResponsiveImage(productCardAsset(product.imageKey));

      return (
        <article class="card">
          <img
            class="content-media"
            src={image.src}
            srcset={image.srcset}
            sizes={image.sizes}
            alt={product.name[lang]}
            loading="lazy"
            decoding="async"
          />
          <h2>{product.name[lang]}</h2>
          <p>{product.description[lang]}</p>
          <a href={localizePath(lang, `/products/${slug}`)}>
            {lang === "ru" ? "Открыть карточку" : "Open page"}
          </a>
        </article>
      );
    })}
  </section>
</BaseLayout>
