---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { photoItems } from "../../../lib/content";
import { LOCALES, localizePath, type Locale } from "../../../lib/i18n";
import { photoDetailAsset, toResponsiveImage } from "../../../lib/media";

export function getStaticPaths() {
  return LOCALES.flatMap((lang) =>
    photoItems.map((photo) => ({
      params: {
        lang,
        slug: photo.slug[lang],
      },
      props: {
        lang,
        photo,
      },
    })),
  );
}

const { lang, photo } = Astro.props as {
  lang: Locale;
  photo: (typeof photoItems)[number];
};

const canonicalPath = localizePath(lang, `/photos/${photo.slug[lang]}`);
const switchUrls = {
  ru: localizePath("ru", `/photos/${photo.slug.ru}`),
  en: localizePath("en", `/photos/${photo.slug.en}`),
};
const image = toResponsiveImage(photoDetailAsset(photo.imageKey));
---

<BaseLayout
  lang={lang}
  title={photo.title[lang]}
  description={photo.description[lang]}
  canonicalPath={canonicalPath}
  switchUrls={switchUrls}
  hreflangUrls={switchUrls}
>
  <article class="card">
    <h1 class="page-title">{photo.title[lang]}</h1>
    <img
      class="content-media content-media--detail"
      src={image.src}
      srcset={image.srcset}
      sizes={image.sizes}
      alt={photo.title[lang]}
      loading="eager"
      decoding="async"
    />
    <p>{photo.description[lang]}</p>
    <p class="muted">{photo.story[lang]}</p>
    <p>
      <a href={localizePath(lang, "/photos")}>{lang === "ru" ? "← Назад к галерее" : "← Back to gallery"}</a>
    </p>
  </article>
</BaseLayout>
