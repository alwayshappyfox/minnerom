---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { metaText, localizedPathPair } from "../../lib/content";
import { LOCALES, localizePath, type Locale } from "../../lib/i18n";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: Locale };
const switchUrls = localizedPathPair(lang, "/");
const canonicalPath = localizePath(lang);

const copy =
  lang === "ru"
    ? {
        heroLine1: "ФОТО BACKGROUND ЛЕЖИТ В ПАПКЕ",
        heroLine2: "MINNE/PHOTO",
        brand: "Minnerom",
        galleryTitle: "Галерея",
        blogTitle: "Блог",
        photoStubLabel: "Фото заглушка",
        textStub: "Текст заглушка",
      }
    : {
        heroLine1: "BACKGROUND PHOTO IS IN FOLDER",
        heroLine2: "MINNE/PHOTO",
        brand: "Minnerom",
        galleryTitle: "Gallery",
        blogTitle: "Blog",
        photoStubLabel: "Photo placeholder",
        textStub: "Text placeholder",
      };

const galleryHref = localizePath(lang, "/photos");
const blogHref = localizePath(lang, "/blog");
---

<BaseLayout
  lang={lang}
  title={metaText.homeTitle[lang]}
  description={metaText.homeDescription[lang]}
  canonicalPath={canonicalPath}
  switchUrls={switchUrls}
  hreflangUrls={{
    ru: localizePath("ru"),
    en: localizePath("en"),
  }}
>
  <div class="LongScroll" data-long-scroll-root>
    <section class="ls-parallax ls-parallax--hero full-bleed" data-parallax-section data-parallax-speed="0.2">
      <figure class="ls-parallax-layer" data-parallax-layer aria-hidden="true">
        <img
          class="ls-photo-image ls-photo-image--hero"
          src="/photo/background-hero.jpg"
          style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;"
          alt=""
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </figure>
      <div class="ls-parallax-content ls-parallax-content--hero">
        <p class="ls-overline">
          {copy.heroLine1}
          <span>{copy.heroLine2}</span>
        </p>
        <div class="ls-brand-badge">{copy.brand}</div>
      </div>
    </section>

    <section class="ls-title-strip full-bleed">
      <h2><a class="ls-title-link" href={galleryHref}>{copy.galleryTitle}</a></h2>
    </section>

    <section class="ls-parallax ls-parallax--content full-bleed" data-parallax-section data-parallax-speed="0.16">
      <figure class="ls-parallax-layer" data-parallax-layer aria-hidden="true">
        <div class="ls-photo-stub ls-photo-stub--gallery"></div>
      </figure>
      <div class="ls-parallax-content ls-parallax-content--center">
        <p class="ls-overline">{copy.photoStubLabel}</p>
        <h3>{copy.textStub}</h3>
      </div>
    </section>

    <section class="ls-title-strip full-bleed">
      <h2><a class="ls-title-link" href={blogHref}>{copy.blogTitle}</a></h2>
    </section>

    <section class="ls-parallax ls-parallax--content full-bleed" data-parallax-section data-parallax-speed="0.14">
      <figure class="ls-parallax-layer" data-parallax-layer aria-hidden="true">
        <div class="ls-photo-stub ls-photo-stub--blog"></div>
      </figure>
      <div class="ls-parallax-content ls-parallax-content--center">
        <p class="ls-overline">{copy.photoStubLabel}</p>
        <h3>{copy.textStub}</h3>
      </div>
    </section>
  </div>

  <script is:inline>
    (() => {
      const root = document.querySelector("[data-long-scroll-root]");
      if (!root) {
        return;
      }

      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (prefersReducedMotion) {
        return;
      }

      const sections = Array.from(root.querySelectorAll("[data-parallax-section]"));
      const layers = sections
        .map((section) => {
          const layer = section.querySelector("[data-parallax-layer]");
          if (!layer) {
            return null;
          }

          const speed = Number.parseFloat(section.getAttribute("data-parallax-speed") || "0.15");
          return { section, layer, speed };
        })
        .filter(Boolean);

      let rafId = 0;
      const updateParallax = () => {
        const viewportCenter = window.innerHeight / 2;
        layers.forEach(({ section, layer, speed }) => {
          const rect = section.getBoundingClientRect();
          const sectionCenter = rect.top + rect.height / 2;
          const delta = (sectionCenter - viewportCenter) * speed * -1;
          layer.style.transform = `translate3d(0, ${delta.toFixed(2)}px, 0)`;
        });
        rafId = 0;
      };

      const queueParallax = () => {
        if (!rafId) {
          rafId = window.requestAnimationFrame(updateParallax);
        }
      };

      window.addEventListener("scroll", queueParallax, { passive: true });
      window.addEventListener("resize", queueParallax);
      window.addEventListener("orientationchange", queueParallax);

      queueParallax();
    })();
  </script>
</BaseLayout>
