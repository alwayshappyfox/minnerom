---
import { DEFAULT_LOCALE, localizePath } from "../lib/i18n";

const fallback = localizePath(DEFAULT_LOCALE);
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Minnerom</title>
    <script is:inline>
      (() => {
        const readCookie = (name) => {
          const cookie = document.cookie
            .split(";")
            .map((part) => part.trim())
            .find((part) => part.startsWith(`${name}=`));

          if (!cookie) {
            return null;
          }

          return cookie.slice(name.length + 1);
        };

        const saved = readCookie("minnerom_lang");
        if (saved === "ru" || saved === "en") {
          window.location.replace(`/${saved}/`);
          return;
        }

        const languages = Array.isArray(navigator.languages)
          ? navigator.languages
          : [navigator.language || ""];

        const isRuLanguage = languages.some((entry) => entry.toLowerCase().startsWith("ru"));
        window.location.replace(isRuLanguage ? "/ru/" : "/en/");
      })();
    </script>
    <noscript>
      <meta http-equiv="refresh" content={`0;url=${fallback}`} />
    </noscript>
  </head>
  <body>
    <p><a href={fallback}>Перейти на сайт / Go to site</a></p>
  </body>
</html>
