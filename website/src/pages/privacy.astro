---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Политика конфиденциальности"
  titleEn="Privacy Policy"
  description="Политика конфиденциальности Minnerom."
  descriptionEn="Minnerom privacy policy."
>
  <h1
    class="page-title"
    data-i18n
    data-i18n-ru="Политика конфиденциальности"
    data-i18n-en="Privacy Policy"
  >
    Политика конфиденциальности
  </h1>
  <article class="card">
    <p
      data-i18n
      data-i18n-ru="Мы собираем только данные, которые вы отправляете через контактную форму. Данные используются для обратной связи и не передаются третьим лицам без необходимости."
      data-i18n-en="We collect only data you submit through the contact form. It is used for replies and is not shared with third parties without necessity."
    >
      Мы собираем только данные, которые вы отправляете через контактную форму. Данные используются
      для обратной связи и не передаются третьим лицам без необходимости.
    </p>
  </article>
</BaseLayout>
