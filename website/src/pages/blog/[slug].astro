---
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  const posts = [
    {
      slug: "start-of-project",
      titleRu: "Запуск проекта",
      titleEn: "Project kickoff",
      date: "24.05.2026",
      contentRu:
        "Сервер на VPS готов: Nginx, HTTPS, автопродление сертификата и базовая структура Astro. Следующий шаг — наполнить контентом фото, блог и витрину.",
      contentEn:
        "The VPS is ready: Nginx, HTTPS, certificate auto-renewal and a base Astro structure. Next step is to fill photos, blog and showcase content.",
    },
  ];

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<BaseLayout title={post.titleRu} titleEn={post.titleEn} description={post.contentRu} descriptionEn={post.contentEn}>
  <article class="card">
    <h1 class="page-title" data-i18n data-i18n-ru={post.titleRu} data-i18n-en={post.titleEn}>
      {post.titleRu}
    </h1>
    <p class="muted">{post.date}</p>
    <p data-i18n data-i18n-ru={post.contentRu} data-i18n-en={post.contentEn}>
      {post.contentRu}
    </p>
    <p>
      <a href="/blog" data-i18n data-i18n-ru="← Назад к блогу" data-i18n-en="← Back to blog">
        ← Назад к блогу
      </a>
    </p>
  </article>
</BaseLayout>
