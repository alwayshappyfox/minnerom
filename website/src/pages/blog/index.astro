---
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = [
  {
    slug: "start-of-project",
    titleRu: "Запуск проекта",
    titleEn: "Project kickoff",
    excerptRu: "Что уже настроено на сервере и как будет развиваться сайт.",
    excerptEn: "What is already configured on the server and how the site will evolve.",
    date: "24.05.2026",
  },
];
---

<BaseLayout title="Блог" titleEn="Blog" description="Блог Minnerom." descriptionEn="Minnerom blog.">
  <h1 class="page-title" data-i18n data-i18n-ru="Блог" data-i18n-en="Blog">Блог</h1>
  <section class="grid">
    {posts.map((post) => (
      <article class="card">
        <h2 data-i18n data-i18n-ru={post.titleRu} data-i18n-en={post.titleEn}>
          {post.titleRu}
        </h2>
        <p class="muted">{post.date}</p>
        <p data-i18n data-i18n-ru={post.excerptRu} data-i18n-en={post.excerptEn}>
          {post.excerptRu}
        </p>
        <a href={`/blog/${post.slug}`} data-i18n data-i18n-ru="Читать" data-i18n-en="Read">
          Читать
        </a>
      </article>
    ))}
  </section>
</BaseLayout>
